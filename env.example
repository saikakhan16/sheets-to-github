# ─── Google Sheets ────────────────────────────────────────────────────────────
# Your Google Sheet ID — found in sheet URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google OAuth Access Token
# Get from: https://developers.google.com/oauthplayground
# Select: Google Sheets API v4 → https://www.googleapis.com/auth/spreadsheets.readonly
GOOGLE_ACCESS_TOKEN=your_google_access_token_here

# ─── Anthropic / Claude ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your_github_username
GITHUB_REPO=sheets-to-github
GITHUB_BRANCH=main
